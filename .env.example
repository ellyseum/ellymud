MAX_PASSWORD_ATTEMPTS=3

# MCP server API key (required for AI / Claude Code integration)
# Generate with: npm run mcp:regen-key
# Or leave blank and the server will prompt to generate one on first start.
# Substituted into .claude/mcp.json at Claude Code startup.
ELLYMUD_MCP_API_KEY=your_generated_api_key_here

# MCP prod API key (only needed if you connect to ellymud.com prod via .claude/mcp-prod.json)
ELLYMUD_MCP_PROD_API_KEY=

# Admin JWT secret
# Generate with: openssl rand -base64 32
JWT_SECRET=mud-admin-secret-key
